# PoopReminder 环境变量配置示例
# 复制此文件为 .env 后修改值（.env 不要提交到 git）

# 运行模式：production=生产；development/空=开发（会自动创建测试账号）
NODE_ENV=production

# 监听端口
PORT=3000

# JWT 签名密钥（必须修改为随机长字符串）
# 生成命令: openssl rand -hex 48
JWT_SECRET=change_me_to_a_long_random_string

# JWT token 有效期（默认 7 天）
# 支持格式: 7d / 24h / 60m / 120000
JWT_EXPIRES_IN=7d
